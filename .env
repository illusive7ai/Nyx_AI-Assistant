# Choose which backend Nyx uses: lmstudio or ollama
NYX_BACKEND=lmstudio

# LM Studio (OpenAI-compatible) settings:
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=qwen1.5-7B-Chat-GGUF   # name is informational for logs; LM Studio picks the loaded model

# Ollama fallback (optional):
OLLAMA_MODEL=qwen2.5:latest

